function ExtractSystemDir:String;
var
VarDir:array[0..MAX_PATH] of Char;
begin

 if IsWindows64 = False then
 begin
 GetSystemDirectory(VarDir,MAX_PATH);
 Result:=StrPas(VarDir);
 end
 else
 Result:=ExtractWindowsDir+'\SysWOW64'

end;
//------------------------------------------------------------------------------
//------------------------------------------------------------------------------
function ExtractWindowsDir:String;
var
Buffer:array[0..MAX_PATH] of Char;
begin
GetWindowsDirectory(Buffer,MAX_PATH);
Result:=pchar(StrPas(Buffer));
end;
