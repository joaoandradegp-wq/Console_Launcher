function Executa_Tela_Cheia(Caminho_Emulador,Classe_Emulador:String):Boolean;
var
nHandle:HWnd;
begin
Caminho_Emulador:=ExtractFileName(Caminho_Emulador);

    //VERIFICA SE EXECUTÁVEL DO EMULADOR ESTÁ ATIVO
    while IsRunningProcess(Caminho_Emulador) = True do
    begin
    //RECEBE O NOME DA CLASSE DO EXECUTÁVEL DO EMULADOR
    nHandle:=FindWindow(pchar(Classe_Emulador),nil);

      if  nHandle <> 0 then
      begin
      BringWindowToTop(nHandle);
      //SIMULA VIRTUALMENTE O ALT+ENTER
      keybd_event(VK_MENU,  0,0,0);
      keybd_event(VK_RETURN,0,0,0);
      keybd_event(VK_RETURN,0,KEYEVENTF_KEYUP,0);
      keybd_event(VK_MENU,  0,KEYEVENTF_KEYUP,0);
      Result:=True;
      Break;
      end
      else
      Result:=False;

    end;

end;
