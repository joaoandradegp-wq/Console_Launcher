begin

 Try
 Result:=True;
 ShellExecute(Application.Handle,'open',pchar(Diretorio),nil,nil,SW_SHOWNORMAL);
 Except
 Result:=False;
 VarMsgGeral:=Mensagens_Privadas(11,'',Diretorio,'');
 MessageBox(Application.Handle,pchar(VarMsgGeral)
                              ,pchar(Application.Title),MB_ICONERROR+MB_OK);
 end;

