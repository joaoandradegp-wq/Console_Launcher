function Contar_Arquivo(Diretorio,Nome:String):Integer;
var
Rec:TSearchRec;
VarProcura,VarContador:Integer;
begin
VarContador:=0;
VarProcura:=SysUtils.FindFirst(Diretorio+Nome,faAnyFile,Rec);

 while VarProcura = 0 do
 begin
 Inc(VarContador);
 VarProcura:=SysUtils.FindNext(Rec);
 end;

SysUtils.FindClose(Rec);
Result:=VarContador;
end;
