function ColorirLista(Control:TWinControl;Index:Integer;Rect:TRect;State:TOwnerDrawState;
                      CorSim,CorNao,CorLetra_Select,CorFundo_Select:String):Boolean;
begin

 with (Control as TListBox).Canvas do
 begin
    if Index mod 2 = 0 then
    begin
    Brush.Color := HexToColor(CorSim);
    Font.Color := clWhite;
    end
    else
    Brush.Color := HexToColor(CorNao);

    if odSelected in State then
    begin
    Font.Color := HexToColor(CorLetra_Select);
    Font.Style := [fsBold];
    Brush.Color := HexToColor(CorFundo_Select);
    end;

 Brush.Style := bsSolid;
 FillRect(Rect);
 Brush.Style := bsClear;
 TextOut(Rect.Left, Rect.Top,(Control as TListBox).Items[Index]);
 end;

{NĂO UTILIZADO}
Result:=True;
end;
