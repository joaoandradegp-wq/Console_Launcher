function NomePastaAtual(Arquivo:String):String;
var
VarPosicao:Integer;
VarCaminho:String;
begin
//-------------------------------
Arquivo:=ExtractFileDir(Arquivo);
//-------------------------------

VarPosicao:=Pos('\',Inverte_String(Arquivo));
VarCaminho:=Inverte_String(Copy(Arquivo,0,Length(Arquivo)));

Result:=Inverte_String(Copy(VarCaminho,1,VarPosicao-1));
end;
