function Config_Fusion_MultiConsole:String;
var
VarCaminho,Config_Raiz,Config_Individual:String;
Arquivo:TStringList;
begin
VarCaminho:=Diretorio_Global+ExtractFilePath(Array_Consoles[id_console][6]);
Config_Raiz:=Diretorio_Global+'Config\'+Array_Consoles[id_console][11];
Config_Individual:=ExtractName(Diretorio_Global+ExtractFilePath(Array_Consoles[id_console][6])
                  +Array_Consoles[id_console][11])
                  +' - '+Array_Consoles[id_console][2]
                  +ExtractFileExt(Array_Consoles[id_console][11]);

  //CASO NĂO EXISTA O ARQUIVO INDIVIDUAL, ELE COPIA DO ".\CONFIG\Fusion.ini"
  if FileExists(VarCaminho+Config_Individual) = False then
  begin
  //-------------------------------------------------
  FileCopy(Config_Raiz,VarCaminho+Config_Individual);
  //-------------------------------------------------
  Arquivo:=TStringList.Create;
  Arquivo.LoadFromFile(VarCaminho+Config_Individual);
  Arquivo.SaveToFile(VarCaminho+Config_Individual);
  Arquivo.Free;
  end;
  
Result:=VarCaminho+Config_Individual;
end;
