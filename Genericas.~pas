function Executar_Esperar(Executavel,Parametro,Arquivo_DLL,SaveLoad,Classe_Emulador:String):Boolean;
var
Sh:TShellExecuteInfo;
CodigoSaida:DWORD;
i:Integer;
begin

//----------------------------------------------------------------
if Length(Arquivo_DLL) > 0 then
begin

 {COPIA A QUANTIDADE DE DLL QUE ESTIVER DEFINIDA NO Array_Consoles}
 for i:=0 to Contar_Delimitador(';',Array_Consoles[id_console][12])-1 do
 Result:=Verifica_DLL(SplitString(Arquivo_DLL,';')[i],Diretorio_Global+'Lib\'+
                      SplitString(Arquivo_DLL,';')[i],ExtractSystemDir+'\'+SplitString(Arquivo_DLL,';')[i]);

end
else
Result:=True;
//----------------------------------------------------------------

if Result = True then
begin
FillChar(Sh,SizeOf(Sh),0);
Sh.cbSize:=SizeOf(TShellExecuteInfo);

  With Sh do
  begin
  fMask:=SEE_MASK_NOCLOSEPROCESS;
  Wnd:=Application.Handle;
  lpVerb:=nil;
  lpFile:=PChar(Executavel);
  lpParameters:=PChar(Parametro);
   //---------------------------------------------------------
   //VIRA "TRUE" NA FUNÇĂO "Carregar_Emulador"
   if Form1.Enabled = True then
   nShow:=SW_SHOWNORMAL //QUANDO ABRIR PELO MENU
   else
   nShow:=SW_HIDE;      //QUANDO ABRIR PELA LISTAGEM DE JOGOS
   //---------------------------------------------------------
  end;

  if ShellExecuteEx(@Sh) then
  begin
  PID_Emulador:=Sh.hProcess;

   //---------------------------------------------
   {PLAYSTATION}
   if id_console = 6 then
   Executa_Tela_Cheia(Executavel,Classe_Emulador);
   //---------------------------------------------

    //CASO EXECUTE PELA LISTAGEM, GRAVA AS TECLAS DE ATALHO
    //--------------------------------------------------------------
    if (Length(Parametro) > 0) and (Erro_Salvar_Config = False) then
    SaveLoadState(True,SaveLoad);
    //--------------------------------------------------------------

   REPEAT
   Application.ProcessMessages;
   GetExitCodeProcess(Sh.hProcess,CodigoSaida);
   UNTIL not(CodigoSaida=STILL_ACTIVE);

  //----------------------
  PID_Emulador:=0;
  SaveLoadState(False,'');
  //----------------------
  DeleteFile(ExtractFilePath(Application.ExeName)+ExtractFilePath(Array_Consoles[id_console][6])+'stderr.txt');
  DeleteFile(ExtractFilePath(Application.ExeName)+ExtractFilePath(Array_Consoles[id_console][6])+'stdout.txt');
  Result:=True;
  end
  else
  Result:=False;
end;

end;
