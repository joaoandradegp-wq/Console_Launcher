function  Localiza_Move_Plugin(DiretorioRaiz,SubDiretorio_Plugin,Nome_Plugin:String):Boolean;
var
SearchRec: TSearchRec;
begin
DiretorioRaiz:=Trim(DiretorioRaiz);

 if DiretorioRaiz[Length(DiretorioRaiz)] <> '' then
 DiretorioRaiz:=DiretorioRaiz + '';
                                     
SetCurrentDir(DiretorioRaiz);

 if FindFirst('*'+ExtractFileExt(Nome_Plugin), faAnyFile, SearchRec) = 0 then
 Repeat
  if not (SearchRec.Name = Nome_Plugin) then
  begin
   if DirectoryExists(DiretorioRaiz+SubDiretorio_Plugin) = False then
   ForceDirectories(DiretorioRaiz+SubDiretorio_Plugin);
    Try
    FileCopy(DiretorioRaiz+SearchRec.Name,DiretorioRaiz+SubDiretorio_Plugin+'\'+SearchRec.Name);
    Finally
    DeleteFile(DiretorioRaiz+SearchRec.Name);
    end;
  end;
 Until FindNext(SearchRec) <> 0;

FindClose(SearchRec);

{NĂO UTILIZADO}
Result:=True;
end;
