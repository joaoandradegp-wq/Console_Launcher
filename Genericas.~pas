function Trocar_String(S,Localizar,Substituir:String):String;
var
VarRetorno:String;
VarPosicao:Integer;
begin
VarRetorno:=S;
VarPosicao:=Pos(Localizar,VarRetorno);

 if VarPosicao <> 0 then
 begin
 Delete(VarRetorno,VarPosicao,Length(Localizar));
 Insert(Substituir,VarRetorno,VarPosicao);
 end;

Result:=VarRetorno;
end;
