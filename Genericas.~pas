function NovoUpdate(Url:String): Boolean;
var
aux: String;
VarHTTP: TIdHTTP;
begin
Result:=False;
aux:='';

VarHTTP:=TIdHTTP.Create(nil);
VarHTTP.HandleRedirects:=True;

  Try
  //-------------------------------
   if pos('http://',Url) > 0 then
   aux:=VarHTTP.Get(Url)
   else
   aux:=VarHTTP.Get('http://'+Url);
  //-------------------------------
  Except
  //-------------------------------------------------------------------------------
    if Length(aux) = 0 then
    begin
      case MessageBox(Application.Handle,pchar(Mensagens_Privadas(3,VersaoApp_Global,'',''))
                                        ,pchar(Application.Title)
                                        ,MB_ICONQUESTION+MB_YESNO+MB_DEFBUTTON2) of
      idYes: Result:=True;
       idNo: Result:=False;
      end;
    end;
  //-------------------------------------------------------------------------------
  end;

VarHTTP.Free;
end;
