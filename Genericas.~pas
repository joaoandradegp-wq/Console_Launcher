function Verifica_DLL(Emulador_DLL,Origem_DLL,Destino_DLL_System32:String):Boolean;
begin

 {VERIFICA SE EXISTE A DLL INSTALADA NA PASTA SYSTEM DO WINDOWS}
 if not FileExists(Destino_DLL_System32) then
 begin
   {CASO NĂO EXISTA, VERIFICA SE EXISTE A DLL NA PASTA "LIB" DO CONSOLE LAUNCHER}
   if FileExists(Origem_DLL) then
   begin
    {COPIA DA PASTA "LIB" DO CONSOLE LAUNCHER PARA O COMPUTADOR}
    Try
    FileCopy(Origem_DLL,Destino_DLL_System32);
    Result:=True;
    Except
    Result:=False;
    VarMsgGeral:=Mensagens_Privadas(1,'',Emulador_DLL,'');
    MessageBox(Application.Handle,pchar(VarMsgGeral)
                                 ,pchar(Application.Title),MB_ICONERROR+MB_OK);
    end;
   end
   else
   begin
   Result:=False;
   VarMsgGeral:=Mensagens_Privadas(2,'',Emulador_DLL,'');
   MessageBox(Application.Handle,pchar(VarMsgGeral)
                                ,pchar(Application.Title),MB_ICONERROR+MB_OK);
   end;
 end
 else
 Result:=True;

end;
