function Bloquear_Caracteres(Campo:String):Boolean;
var
i:Integer;
begin
i:=1;
Result:=False;

 while i < Length(Campo)+1 do
 begin
  //----------------------------------------------
  if (Campo[i] in ['0'..'9','a'..'z','A'..'Z']) or
     (Campo[i] =  ' ') or
     (Campo[i] =  '(') or
     (Campo[i] =  ')') or
     (Campo[i] =  '-') or
     (Campo[i] =  '.') then
  begin
  Result:=False;
  Inc(i);
  end
  else
  begin
  Result:=True;
  Break;
  end;
  //----------------------------------------------
 end;

end;
