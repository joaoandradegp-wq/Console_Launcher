function Verificar_Status(Verifica:Boolean;Flag_Imagem:TImage):Integer;
begin

if Verifica = True then
begin
Flag_Imagem.Picture.Assign(Nil);

  case GetDriveType(PChar(Diretorio_Global[1] + ':\')) of
  3: begin
     Result:=1;
     {Pronto!}
     Form1.Lista_Imagens.GetBitmap(3,Flag_Imagem.Picture.Bitmap);
     Form1.StatusBar1.Panels[1].Text:=Mensagens_Pequenas(Result+2);
     end;
  2: begin
     Result:=2;
     {Aten鈬o - Dispositivo Remov咩el}
     Form1.Lista_Imagens.GetBitmap(4,Flag_Imagem.Picture.Bitmap);
     Form1.StatusBar1.Panels[1].Text:=Mensagens_Pequenas(Result);
     end;
  else
  begin
  Result:=3;
  {ERRO!}
  MessageBox(Application.Handle,pchar(Mensagens_Publicas(Result))
                               ,pchar(Application.Title),MB_ICONERROR+MB_OK);
  Application.Terminate;
  end;
 end;
end
else
begin
Result:=4;
  {APENAS EXIBE MENSAGEM DE STATUS QUANDO ESTIVER "Aten鈬o - Dispositivo Remov咩el"}
  if (Form1.StatusBar1.Panels[1].Text =  Mensagens_Pequenas(2)) or
     (Form1.StatusBar1.Panels[1].Text <> Mensagens_Privadas(15,Array_Consoles[id_console][2],'',Array_Consoles[id_console][9]))
  then
  MessageBox(Application.Handle,pchar(Mensagens_Publicas(1))
                               ,pchar(Application.Title),MB_ICONWARNING+MB_OK);
end;

end;
