procedure RenomearROM;
var
i:Integer;
Caixa_Texto,Nome_Antigo,Nome_Novo,Pesquisa,Pasta_Rom,Nome_Rom:String;
Lista_Arquivos:TStringList;
SearchRec:TSearchRec;
begin
//------------------------------------------------------------------------------------
{CAMINHO COMPLETO DO ARQUIVO DO JOGO LISTADO}
Pasta_Rom:=ExtractFilePath(Vetor_Listagem_Rom[Form1.ListBox1.ItemIndex]);

{NOME DO JOGO NA LISTAGEM (SEM "TRACK" OU "DISC"}
Nome_Rom:=ApagaTrackCD(Trim(Form1.ListBox1.Items[Form1.ListBox1.ItemIndex]));

{PESQUISA PARA SER USADO NO FindFirst}
Pesquisa:=Pasta_Rom+Nome_Rom;
//------------------------------------------------------------------------------------

//--------------------------------------------------------
{PROCURA OS ARQUIVOS RELACIONADOS AO NOME DO JOGO LISTADO}
//--------------------------------------------------------
Lista_Arquivos:=TStringList.Create;

if FindFirst(Pesquisa+'*.*',faAnyFile, SearchRec) = 0 then
REPEAT
Lista_Arquivos.Add(Pasta_Rom+SearchRec.Name);
UNTIL FindNext(SearchRec) <> 0;
FindClose(SearchRec);
//--------------------------------------------------------

//--------------------------------------------------------
{NOME DO JOGO NA CAIXA DE TEXTO - InputQuery}
//--------------------------------------------------------
Caixa_Texto:=Nome_Rom;
//--------------------------------------------------------

REPEAT
 if InputQuery(Application.Title,Mensagens_Pequenas(1),Caixa_Texto) then
 begin

   if (Bloquear_Caracteres(Caixa_Texto) = True) then
   begin
   VarMsgGeral:=Mensagens_Publicas(4);
   MessageBox(Application.Handle,pchar(VarMsgGeral),pchar(Application.Title),MB_ICONWARNING+MB_OK);
   Break;
   end;

   if (FileExists(ExtractFilePath(Pasta_Rom)+Trim(Caixa_Texto)+Copy(Array_Consoles[id_console][4],2,Length(Array_Consoles[id_console][4]))) and (Caixa_Texto <> Nome_Rom)) then
   begin
   VarMsgGeral:=Mensagens_Privadas(6,Array_Consoles[id_console][2],'',UpperCase(Array_Consoles[id_console][9]));
   MessageBox(Application.Handle,pchar(VarMsgGeral),pchar(Application.Title),MB_ICONWARNING+MB_OK);
   Break;
   end;

   if LowerCase(Array_Consoles[id_console][9]) = 'cd' then
   begin
    {INICIO - FOR}
    for i := 0 to Lista_Arquivos.Count - 1 do
    begin
    Nome_Antigo:=Lista_Arquivos.Strings[i];
    Nome_Novo  :=ExtractFilePath(Nome_Antigo);
    Nome_Novo  :=StringReplace(Nome_Antigo,Nome_Rom,UpperCase(Caixa_Texto),[rfReplaceAll,rfIgnoreCase]);

      //--------------------------------------------------------------------------------------------------
      {SEGA CD}
      //--------------------------------------------------------------------------------------------------
      if id_console = 5 then
      begin
      MoveFile(pchar(ExtractFilePath(Nome_Antigo)),pchar(ExtractFilePath(Nome_Novo)));//RENOMEIA PASTA
      RenameFile(ExtractFilePath(Nome_Novo)+ExtractFileName(Nome_Antigo),Nome_Novo);  //RENOMEIA ARQUIVOS
      end
      //--------------------------------------------------------------------------------------------------
      else
      RenameFile(Nome_Antigo,Nome_Novo);

    end;
    {FIM - FOR}
   end
   else
   begin
     if (Length(Trim(Caixa_Texto)) > 0) then
     RenameFile(Pasta_Rom+Nome_Rom              +Copy(Array_Consoles[id_console][4],2,Length(Array_Consoles[id_console][4]))
               ,Pasta_Rom+UpperCase(Caixa_Texto)+Copy(Array_Consoles[id_console][4],2,Length(Array_Consoles[id_console][4])));
   end;

 end
 else
 Break;
UNTIL (Caixa_Texto <> Nome_Rom) and (Length(Trim(Caixa_Texto)) > 0);

Lista_Arquivos.Free;
end;
