function ApagaTrackCD(Titulo_Jogo:String):String;
var
INI,FIM:Integer;
deletar:String;
begin
Result:=Titulo_Jogo;

//----------------------------
INI:=Pos('(',Result);
FIM:=Pos(')',Result);
deletar:=Copy(Result,INI,FIM);
//----------------------------

{SE TIVER "CD" EM PARENTESES, ADICIONA AO NOME}
if (Length(deletar) > 0) and ((deletar[2]  = 'c') and (deletar[3]  = 'd')) then
begin
 {SE A NOMECLATURA FOR DE "CD 01" AO INVﾉS DE "CD 1"}
 if deletar[5] = '0' then
 Result:=(Copy(Result,0,INI-1) + Copy(Result,INI,7))
 else
 Result:=(Copy(Result,0,INI-1) + Copy(Result,INI,6));
end;

{SE NﾃO TIVER "CD" EM PARENTESES, LIMPA O QUE TIVER DEPOIS DO NOME}
if (Length(deletar) > 0) and ((deletar[2] <> 'c') and (deletar[3] <> 'd'))then
Result:=Copy(Result,0,INI-1);

Result:=Trim(Result);
end;
