function Habilita_Emulador(Caminho_Emulador,Caminho_Rom,Nome_Console:String):Boolean;
begin

 {VERIFICA SE EXISTE O EXECUTﾁVEL DO EMULADOR}
 if FileExists(Caminho_Emulador) then
 begin
 Result:=True;
   {SE EXISTIR O EMULADOR, VERIFICA SE EXISTE A PASTA DE ROMS}
   if not DirectoryExists(Caminho_Rom) then
   begin
     Try
     ForceDirectories(Caminho_Rom);
     Result:=True;
     Except
     Result:=False;
     VarMsgGeral:=Mensagens_Privadas(4,Nome_Console,'','');
     MessageBox(Application.Handle,pchar(VarMsgGeral)
                                  ,pchar(Application.Title),MB_ICONERROR+MB_OK);
     end;
   end;
 end
 else
 Result:=False;

end;
