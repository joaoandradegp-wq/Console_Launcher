function Resolucao_Tela_Fusion(Resolucao:Integer):String;
var
VarAux:Double;
begin
 {
 DResolution=0,3,0,4
 1024x768
 0 + (256 * 3) = 768
 0 + (256 * 4) = 1024
 }
 VarAux:=Resolucao/256;
 Result:=IntToStr(Trunc(VarAux));

 VarAux:=Trunc(VarAux)*256;
 VarAux:=Resolucao-VarAux;

 Result:=IntToStr(Trunc(VarAux))+','+Result;
end;
