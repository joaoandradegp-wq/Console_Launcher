function SaveLoadState(Marcador:Boolean;Teclas:String):Boolean;
var
i:Integer;
begin

if Marcador = False then
begin

 //-------------------------------
 for i:=1 to 17 do
 UnRegisterHotkey(Form1.Handle,i);
 //-------------------------------

Result:=True; 
end
else
begin
 Try
   //----------------------------------------------------------
   if SaveState_Global <> StrToInt(Trim(Copy(Teclas,0,3))) then //SAVESTATE
   RegisterHotkey(Form1.Handle,13,0,SaveState_Global);
   //----------------------------------------------------------
   if LoadState_Global <> StrToInt(Trim(Copy(Teclas,4,3))) then //LOADSTATE
   RegisterHotkey(Form1.Handle,14,0,LoadState_Global);
   //----------------------------------------------------------

   //------------------------------------------------
   RegisterHotkey(Form1.Handle,15,0      ,VK_ESCAPE); //ESC
   RegisterHotkey(Form1.Handle,16,MOD_ALT,VK_F4    ); //ALT+F4
   RegisterHotkey(Form1.Handle,17,MOD_ALT,VK_RETURN); //ALT+ENTER

   //------------------------------------------------

   //------------------------------------------------
   Anular_Teclas(Copy(Teclas,0,3),Copy(Teclas,4,6));
   //------------------------------------------------
 Result:=True;
 Except
  VarMsgGeral:=Mensagens_Privadas(5,Array_Consoles[id_console][2],'','');
  MessageBox(Application.Handle,pchar(VarMsgGeral)
                               ,pchar(Application.Title),MB_ICONERROR+MB_OK);
