function Renomear_Extensao(Caminho_Atual,Caminho_Emulador,Nome_Jogo,Extensao_Original:String):Boolean;
var
SearchResult:TSearchRec;
VarNomeJogo:String;
VarQuantidade:Integer;
begin
VarQuantidade:=0;
VarNomeJogo:=Nome_Jogo;
//---------------------------------------------
Extensao_Original:=Copy(Extensao_Original,2,5);
//---------------------------------------------

   if ((Caminho_Atual) = (Caminho_Emulador)) then
   begin
     //----------------------------------------------------------------------------------------------------------------------
     if FileExists(ChangeFileExt(Caminho_Atual+VarNomeJogo,'')+Extensao_Original) then
     begin
        if FindFirst(ChangeFileExt(Caminho_Atual+VarNomeJogo,'')+'*', faAnyFile, SearchResult) = 0 then
        begin
         REPEAT
         //CONTAR QUANTOS ROMS EXISTEM REPETIDOS (MESMO NOME, POIS PODE TER MAIS DE 1 COM EXTENSﾃO DIFERENTE)
         Inc(VarQuantidade);
         UNTIL FindNext(SearchResult) <> 0;
        FindClose(SearchResult);
        end;
     VarNomeJogo:=ChangeFileExt(VarNomeJogo,'')+' ('+Formatfloat('00',VarQuantidade)+')'+Extensao_Original;
     end;
     //----------------------------------------------------------------------------------------------------------------------
     REPEAT
     RenameFile(Caminho_Atual+Nome_Jogo,ChangeFileExt(Caminho_Atual+VarNomeJogo,'')+Extensao_Original);
       if not FileExists(Caminho_Atual+Nome_Jogo) then
       Break;
     UNTIL FileExists(ChangeFileExt(Caminho_Atual+VarNomeJogo,'')+Extensao_Original);
     //----------------------------------------------------------------------------------------------------------------------
   end;

{NﾃO UTILIZADO}
Result:=True;
end;
